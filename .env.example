# Hyperclip API key (starts with hck_live_...).
# Create one in the Hyperclip app under Settings → Developer.
# This is server-only — never expose it to the browser.
HYPERCLIP_API_KEY=

# UUID of the saved autocaption flow this app should run.
# Find via: curl https://zjasnfhprfiftozodqsz.supabase.co/functions/v1/api-v1/flows \
#   -H "Authorization: Bearer $HYPERCLIP_API_KEY"
HYPERCLIP_FLOW_ID=

# Zero-based step index of the media_input node in your flow.
# Inspect via: curl .../flows/$HYPERCLIP_FLOW_ID -H "Authorization: Bearer $HYPERCLIP_API_KEY"
# and read the `required_inputs` array. For most caption-only flows this is 0.
HYPERCLIP_VIDEO_STEP_INDEX=0

# Zero-based step index of the auto_captions node in your flow. Used to send
# the chosen caption style preset as inputs.model_overrides[<n>]._caption_style.
# For the canonical media_input → auto_captions → video_editor flow this is 1.
HYPERCLIP_CAPTION_STEP_INDEX=1

# Optional. Defaults to Hyperclip production
# (https://zjasnfhprfiftozodqsz.supabase.co/functions/v1/api-v1).
# Only set this for staging or self-hosted Hyperclip instances.
# HYPERCLIP_BASE_URL=

# Vercel Blob token — automatically injected on Vercel when you enable the
# Blob integration. For local dev, copy it out of the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=
